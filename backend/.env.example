# MongoDB Atlas (FREE)
# Get your free connection string from https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-voice-db?retryWrites=true&w=majority
MONGODB_DB=ai-voice-db

# Google Gemini API (FREE)
# Get your free API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000